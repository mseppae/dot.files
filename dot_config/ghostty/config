# Ghostty config
# Shell integration enables Neovim-aware split navigation via smart-splits.nvim

font-family = JetBrainsMono Nerd Font

# Unbind ctrl+, (default: open_config) so it passes through to Neovim
keybind = ctrl+,=unbind

# Splits — mirror WezTerm leader key bindings (leader = ctrl+\)
keybind = ctrl+\>minus=new_split:down
keybind = ctrl+\>equal=new_split:right
keybind = ctrl+\>m=toggle_split_zoom
keybind = ctrl+\>enter=toggle_split_zoom

# Navigate splits — handled by smart-splits.nvim via Ghostty IPC
# (ctrl+hjkl keybinds are NOT set here; smart-splits calls ghostty @ goto-split at Neovim window edges)

# Resize splits (alt+hjkl)
keybind = alt+h=resize_split:left,10
keybind = alt+j=resize_split:down,10
keybind = alt+k=resize_split:up,10
keybind = alt+l=resize_split:right,10
