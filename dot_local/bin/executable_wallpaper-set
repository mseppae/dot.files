#!/bin/bash
set -euo pipefail

WALLPAPER="$1"

if [[ -z "$WALLPAPER" ]]; then
  echo "Usage: wallpaper-set /path/to/image.jpg"
  exit 1
fi

if [[ ! -f "$WALLPAPER" ]]; then
  echo "Error: file not found: $WALLPAPER"
  exit 1
fi

WALLPAPER="$(realpath "$WALLPAPER")"
echo "Setting wallpaper: $WALLPAPER"

awww img "$WALLPAPER" --transition-type fade --transition-duration 1

matugen image "$WALLPAPER"

hyprctl reload

pkill waybar || true
sleep 0.3
waybar &
disown

makoctl reload

echo "Done. Wallpaper and colors updated."
