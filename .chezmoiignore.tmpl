.config/gtk-3.0
.config/gtk-4.0
.config/gnome-shell
{{ end }}

# KDE configs — Bazzite KDE only
{{ if or (ne .chezmoi.os "linux") (ne (default "" (index .chezmoi.osRelease "variant_id")) "bazzite") }}
