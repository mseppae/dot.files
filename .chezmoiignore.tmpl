.config/ghostty/colors.conf
.config/waybar/colors.css
.config/mako/colors
.config/rofi/colors.rasi

# Repo meta files — not deployed to home directory
README.md
Dockerfile
CLAUDE.md

# macOS LaunchAgents — macOS only
{{ if ne .chezmoi.os "darwin" }}
Library
{{ end }}

# Hyprland configs — Arch Linux only
