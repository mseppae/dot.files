#!/bin/bash
# chezmoi run_once_ script: runs on first apply (or when this file changes).
# Purpose: bootstrap a new machine. Does NOT upgrade already-installed tools.
# For ongoing upgrades use: topgrade

set -euo pipefail

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# OS and distro detection
OS="$(uname -s)"
DISTRO="unknown"
if [[ "$OS" == "Linux" ]] && [[ -f /etc/os-release ]]; then
  _variant_id="$(. /etc/os-release && echo "${VARIANT_ID:-}")"
  _os_id="$(. /etc/os-release && echo "${ID:-unknown}")"
  case "$_variant_id" in
    bazzite) DISTRO="bazzite" ;;
    *)
      case "$_os_id" in
        arch) DISTRO="arch" ;;
        *)    DISTRO="$_os_id" ;;
      esac
      ;;
  esac
  unset _variant_id _os_id
fi

# Ensure Linuxbrew is on PATH if already installed
if [[ -f /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Install Homebrew / Linuxbrew if not present
if [[ "$OS" == "Darwin" ]]; then
    if ! command_exists brew; then
        echo "macOS detected. Homebrew not found. Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        if [[ "$(uname -m)" == "arm64" ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        else
            eval "$(/usr/local/bin/brew shellenv)"
        fi
        echo "Homebrew installed."
    else
        echo "Homebrew is already installed."
    fi
elif [[ "$DISTRO" == "bazzite" ]] || [[ "$DISTRO" == "arch" ]]; then
    if ! command_exists brew; then
        echo "$DISTRO detected. Installing Linuxbrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
        echo "Linuxbrew installed."
    else
        echo "Linuxbrew is already installed."
    fi
else
    echo "Not on macOS, Bazzite, or Arch ($OS / $DISTRO). Skipping Homebrew installation."
fi

# Install tools via Homebrew
BREW_APPS=("zsh" "vivid" "zoxide" "fzf" "ripgrep" "bob" "topgrade" "fastfetch" "coreutils" "openssl" "readline" "libyaml" "libffi" "mise")

if command_exists brew; then
    for app in "${BREW_APPS[@]}"; do
        if ! brew list --formula "$app" &>/dev/null 2>&1; then
            echo "Installing $app via Homebrew..."
            brew install "$app"
        else
            echo "$app is already installed."
        fi
    done
else
    echo "Homebrew not available. Install manually: ${BREW_APPS[*]}"
fi

# Install mise (fallback for non-brew systems)
if ! command_exists mise; then
    echo "Installing mise via official script..."
    curl -fsSL https://mise.jdx.dev/install.sh | sh
    echo "Mise installed."
fi

# Bootstrap mise runtimes early — needed before AUR builds (mise Python used by makepkg)
if command_exists mise; then
    mise trust "$HOME/.config/mise/config.toml"
    mise install
    eval "$(mise activate bash)"
    mise exec python -- pip install --quiet --upgrade build setuptools wheel installer attrs numpy pillow toml pyyaml
fi

# Bootstrap paru (AUR helper) on Arch
if [[ "$DISTRO" == "arch" ]] && ! command_exists paru; then
    echo "Installing paru (AUR helper)..."
    sudo pacman -S --needed --noconfirm base-devel git
    git clone https://aur.archlinux.org/paru.git /tmp/paru-build
    (cd /tmp/paru-build && makepkg -si --noconfirm)
    rm -rf /tmp/paru-build
fi

# Install Ghostty
if ! command_exists ghostty; then
    if [[ "$DISTRO" == "bazzite" ]]; then
        echo "Installing Ghostty via rpm-ostree (requires reboot to take effect)..."
        . /etc/os-release
        curl -fsSL "https://copr.fedorainfracloud.org/coprs/scottames/ghostty/repo/fedora-${VERSION_ID}/scottames-ghostty-fedora-${VERSION_ID}.repo" \
            | sudo tee /etc/yum.repos.d/_copr_scottames-ghostty.repo > /dev/null
        rpm-ostree refresh-md && rpm-ostree install -y ghostty
    elif [[ "$DISTRO" == "arch" ]]; then
        echo "Installing Ghostty via paru..."
        paru -S --noconfirm ghostty
    elif [[ "$OS" == "Darwin" ]]; then
        echo "Installing Ghostty via Homebrew Cask..."
        brew install --cask ghostty
    else
        echo "Please install Ghostty manually: https://ghostty.org"
    fi
else
    echo "Ghostty is already installed."
fi

# Arch: Hyprland desktop stack
if [[ "$DISTRO" == "arch" ]]; then
    # Enable multilib repo (required for 32-bit Steam/gaming libraries)
    if ! grep -q '^\[multilib\]' /etc/pacman.conf; then
        echo "Enabling multilib repository..."
        sudo sed -i '/^#\[multilib\]/{n;s/^#Include/Include/;s/^#\[multilib\]/[multilib]/}' /etc/pacman.conf
        sudo pacman -Sy
    fi

    ARCH_PACKAGES=(
        # Hyprland + Wayland
        hyprland hyprland-guiutils
        xdg-desktop-portal-hyprland xdg-desktop-portal-gtk
        qt5-wayland qt6-wayland
        polkit-kde-agent
        # Display manager
        sddm
        # Desktop components
        waybar wofi mako awww hyprlock hypridle
        # Utilities
        grim slurp wl-clipboard brightnessctl playerctl openssh unzip fd
        tree-sitter tree-sitter-cli
        # Fonts (required by mako, waybar, neovim)
        ttf-nerd-fonts-symbols ttf-nerd-fonts-symbols-mono ttf-jetbrains-mono-nerd
        # GTK theming
        nwg-look adw-gtk-theme papirus-icon-theme
        # Apps
        thunar gvfs imv zathura zathura-pdf-mupdf mpv file-roller p7zip godot
        # GPU drivers (AMD/RADV)
        mesa lib32-mesa vulkan-radeon lib32-vulkan-radeon
        libva-mesa-driver lib32-libva-mesa-driver vulkan-tools
        # Audio (PipeWire)
        pipewire pipewire-alsa pipewire-pulse pipewire-jack
        wireplumber lib32-pipewire helvum
        # Bluetooth
        bluez bluez-utils
        # Gaming
        steam lutris wine-staging winetricks
        gamemode lib32-gamemode mangohud lib32-mangohud
        flatpak obs-studio
    )
    MISSING_ARCH_PACKAGES=()
    for pkg in "${ARCH_PACKAGES[@]}"; do
        pacman -Q "$pkg" &>/dev/null || MISSING_ARCH_PACKAGES+=("$pkg")
    done
    if [[ ${#MISSING_ARCH_PACKAGES[@]} -gt 0 ]]; then
        echo "Installing Arch desktop packages: ${MISSING_ARCH_PACKAGES[*]}"
        sudo pacman -S --needed --noconfirm "${MISSING_ARCH_PACKAGES[@]}"
    else
        echo "All Arch desktop packages already installed."
    fi

    # AUR packages
    if command_exists paru; then
        for aur_pkg in matugen-bin sddm-astronaut-theme bibata-cursor-theme 1password \
                       proton-ge-custom-bin protonup-qt heroic-games-launcher-bin \
                       corectrl flatseal fooyin; do
            if ! pacman -Q "$aur_pkg" &>/dev/null; then
                paru -S --needed --noconfirm "$aur_pkg"
            fi
        done
    fi

    # PipeWire user services
    for _svc in pipewire pipewire-pulse wireplumber; do
        systemctl --user is-enabled "$_svc" &>/dev/null || systemctl --user enable --now "$_svc"
    done

    # GameMode user service
    if pacman -Q gamemode &>/dev/null; then
        systemctl --user is-enabled gamemoded &>/dev/null || systemctl --user enable --now gamemoded
    fi

    # Bluetooth
    if pacman -Q bluez &>/dev/null; then
        systemctl is-enabled bluetooth &>/dev/null || sudo systemctl enable --now bluetooth
    fi

    # Flatpak: add Flathub remote
    if command_exists flatpak && ! flatpak remotes | grep -q flathub; then
        flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
    fi

    # corectrl polkit rule (allow wheel group without password prompt)
    if pacman -Q corectrl &>/dev/null && [[ ! -f /etc/polkit-1/rules.d/90-corectrl.rules ]]; then
        echo "Configuring corectrl polkit rule..."
        sudo mkdir -p /etc/polkit-1/rules.d
        sudo tee /etc/polkit-1/rules.d/90-corectrl.rules >/dev/null <<'POLKIT'
polkit.addRule(function(action, subject) {
    if ((action.id == "org.corectrl.helper.init" ||
         action.id == "org.corectrl.helperkiller.init") &&
        subject.local == true &&
        subject.active == true &&
        subject.isInGroup("wheel")) {
            return polkit.Result.YES;
    }
});
POLKIT
    fi

    # Enable SDDM
    if ! systemctl is-enabled sddm &>/dev/null; then
        echo "Enabling SDDM..."
        sudo systemctl enable sddm
    fi

    # System cursor theme
    if [[ ! -f /usr/share/icons/default/index.theme ]]; then
        echo "Configuring system cursor theme..."
        sudo mkdir -p /usr/share/icons/default
        printf '[Icon Theme]\nInherits=Bibata-Modern-Ice\n' | sudo tee /usr/share/icons/default/index.theme >/dev/null
    fi

    # Set SDDM theme
    if [[ ! -f /etc/sddm.conf.d/theme.conf ]]; then
        echo "Configuring SDDM theme..."
        sudo mkdir -p /etc/sddm.conf.d
        printf '[Theme]\nCurrent=sddm-astronaut-theme\n' | sudo tee /etc/sddm.conf.d/theme.conf >/dev/null
    fi

    # Snapper btrfs snapshots (pre/post on every pacman transaction via snap-pac)
    if ! pacman -Q snapper &>/dev/null; then
        sudo pacman -S --needed --noconfirm snapper snap-pac
    fi
    if command_exists paru && ! pacman -Q snapper-rollback &>/dev/null; then
        paru -S --needed --noconfirm snapper-rollback
    fi
    # Create snapper root config manually — do NOT use `snapper create-config /`
    # as it conflicts with the @snapshots subvolume mounted at /.snapshots
    if [[ ! -f /etc/snapper/configs/root ]]; then
        echo "Creating snapper root config..."
        sudo mkdir -p /etc/snapper/configs
        sudo cp /usr/share/snapper/config-templates/default /etc/snapper/configs/root
        # Register config
        if [[ -f /etc/conf.d/snapper ]]; then
            sudo sed -i 's/^SNAPPER_CONFIGS=.*/SNAPPER_CONFIGS="root"/' /etc/conf.d/snapper
        else
            echo 'SNAPPER_CONFIGS="root"' | sudo tee /etc/conf.d/snapper >/dev/null
        fi
        # Retention: pre/post only, keep last 5 pairs, allow user access
        sudo sed -i \
            -e 's/^TIMELINE_CREATE=.*/TIMELINE_CREATE="no"/' \
            -e 's/^TIMELINE_CLEANUP=.*/TIMELINE_CLEANUP="no"/' \
            -e 's/^NUMBER_CLEANUP=.*/NUMBER_CLEANUP="yes"/' \
            -e 's/^NUMBER_MIN_AGE=.*/NUMBER_MIN_AGE="1800"/' \
            -e 's/^NUMBER_LIMIT=.*/NUMBER_LIMIT="5"/' \
            -e 's/^NUMBER_LIMIT_IMPORTANT=.*/NUMBER_LIMIT_IMPORTANT="3"/' \
            -e 's/^ALLOW_USERS=.*/ALLOW_USERS="'"$(whoami)"'"/' \
            -e 's/^SYNC_ACL=.*/SYNC_ACL="yes"/' \
            /etc/snapper/configs/root
        echo "Snapper root config created."
    fi
    if ! systemctl is-enabled snapper-cleanup.timer &>/dev/null; then
        echo "Enabling snapper-cleanup.timer..."
        sudo systemctl enable --now snapper-cleanup.timer
    fi

    # Suppress kernel messages on active TTY (suspend/resume noise, battery events)
    if [[ ! -f /etc/sysctl.d/99-quiet-printk.conf ]]; then
        echo "Configuring quiet kernel console log level..."
        echo 'kernel.printk = 3 4 1 3' | sudo tee /etc/sysctl.d/99-quiet-printk.conf >/dev/null
        sudo sysctl -p /etc/sysctl.d/99-quiet-printk.conf
    fi

    # Plymouth graphical boot splash + LUKS passphrase prompt
    if command_exists paru && ! pacman -Q plymouth &>/dev/null; then
        echo "Installing Plymouth..."
        paru -S --needed --noconfirm plymouth
    fi
    if pacman -Q plymouth &>/dev/null; then
        # Add plymouth hook to mkinitcpio.conf (idempotent)
        # plymouth must appear before encrypt; no plymouth-encrypt hook since Plymouth 2023+
        if ! grep -q '\bplymouth\b' /etc/mkinitcpio.conf; then
            echo "Adding Plymouth hook to mkinitcpio.conf..."
            sudo sed -i 's/\(HOOKS=([^)]*udev\)/\1 plymouth/' /etc/mkinitcpio.conf
            sudo mkinitcpio -P
        fi
        # Set theme
        if ! plymouth-set-default-theme 2>/dev/null | grep -qx 'spinner'; then
            echo "Setting Plymouth theme to spinner..."
            sudo plymouth-set-default-theme -R spinner
        fi
        # Add quiet splash to all systemd-boot entries (skip if using GRUB)
        if [[ -d /boot/loader/entries ]]; then
            for _entry in /boot/loader/entries/*.conf; do
                if grep -q '^options' "$_entry" && ! grep -q '\bsplash\b' "$_entry"; then
                    echo "Adding splash to $_entry..."
                    sudo sed -i '/^options/ s/$/ splash/' "$_entry"
                fi
            done
        fi
        # Enable Plymouth systemd services
        for _svc in plymouth-quit-wait.service plymouth-read-write.service; do
            if ! systemctl is-enabled "$_svc" &>/dev/null; then
                sudo systemctl enable "$_svc"
            fi
        done
    fi
fi

# Set zsh as default shell
zsh_path="$(command -v zsh || true)"
if [[ -n "$zsh_path" ]] && [[ "$SHELL" != "$zsh_path" ]]; then
    echo "Setting zsh as default shell..."
    if ! grep -qF "$zsh_path" /etc/shells; then
        echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
    fi
    if [[ "$OS" == "Darwin" ]]; then
        chsh -s "$zsh_path"
    elif command_exists usermod; then
        sudo usermod --shell "$zsh_path" "$(whoami)"
    else
        sudo chsh -s "$zsh_path" "$(whoami)"
    fi
    echo "Default shell set to $zsh_path (takes effect on next login)."
fi

# Neovim via bob (nightly build)
if command_exists bob; then
    echo "Installing Neovim nightly via bob..."
    chmod -f u+w ~/.local/share/bob/nvim-bin/nvim 2>/dev/null || true
    bob install nightly
    bob use nightly
fi


# Claude Code (native installer with auto-updates)
if ! command_exists claude; then
    echo "Installing Claude Code..."
    curl -fsSL https://claude.ai/install.sh | sh
else
    echo "Claude Code is already installed."
fi
