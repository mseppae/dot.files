#!/bin/bash
# chezmoi run_once_ script: runs on first apply (or when this file changes).
# Purpose: bootstrap a new machine. Does NOT upgrade already-installed tools.
# For ongoing upgrades use: topgrade

set -euo pipefail

command_exists() {
    command -v "$1" >/dev/null 2>&1
}

# OS and distro detection
OS="$(uname -s)"
DISTRO="unknown"
if [[ "$OS" == "Linux" ]] && [[ -f /etc/os-release ]]; then
  _variant_id="$(. /etc/os-release && echo "${VARIANT_ID:-}")"
  _os_id="$(. /etc/os-release && echo "${ID:-unknown}")"
  case "$_variant_id" in
    bazzite) DISTRO="bazzite" ;;
    *)
      case "$_os_id" in
        arch) DISTRO="arch" ;;
        *)    DISTRO="$_os_id" ;;
      esac
      ;;
  esac
  unset _variant_id _os_id
fi

# Ensure Linuxbrew is on PATH if already installed
if [[ -f /home/linuxbrew/.linuxbrew/bin/brew ]]; then
  eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
fi

# Install Homebrew / Linuxbrew if not present
if [[ "$OS" == "Darwin" ]]; then
    if ! command_exists brew; then
        echo "macOS detected. Homebrew not found. Installing Homebrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        if [[ "$(uname -m)" == "arm64" ]]; then
            eval "$(/opt/homebrew/bin/brew shellenv)"
        else
            eval "$(/usr/local/bin/brew shellenv)"
        fi
        echo "Homebrew installed."
    else
        echo "Homebrew is already installed."
    fi
elif [[ "$DISTRO" == "bazzite" ]]; then
    if ! command_exists brew; then
        echo "Bazzite detected. Installing Linuxbrew..."
        /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
        eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
        echo "Linuxbrew installed."
    else
        echo "Linuxbrew is already installed."
    fi
else
    echo "Not on macOS or Bazzite ($OS / $DISTRO). Skipping Homebrew installation."
fi

# Install tools via Homebrew
BREW_APPS=("zsh" "vivid" "starship" "zoxide" "rg" "bob" "topgrade")

if [[ "$DISTRO" == "bazzite" ]]; then
    BREW_APPS+=("openssl" "readline" "libyaml" "libffi")
fi

if command_exists brew; then
    for app in "${BREW_APPS[@]}"; do
        if ! command_exists "$app"; then
            echo "Installing $app via Homebrew..."
            brew install "$app"
        else
            echo "$app is already installed."
        fi
    done
else
    echo "Homebrew not available. Install manually: ${BREW_APPS[*]}"
fi

# Install Ghostty
if ! command_exists ghostty; then
    if [[ "$DISTRO" == "bazzite" ]]; then
        echo "Installing Ghostty via rpm-ostree (requires reboot to take effect)..."
        . /etc/os-release
        curl -fsSL "https://copr.fedorainfracloud.org/coprs/scottames/ghostty/repo/fedora-${VERSION_ID}/scottames-ghostty-fedora-${VERSION_ID}.repo" \
            | sudo tee /etc/yum.repos.d/_copr_scottames-ghostty.repo > /dev/null
        rpm-ostree refresh-md && rpm-ostree install -y ghostty
    elif [[ "$OS" == "Darwin" ]]; then
        echo "Installing Ghostty via Homebrew Cask..."
        brew install --cask ghostty
    else
        echo "Please install Ghostty manually: https://ghostty.org"
    fi
else
    echo "Ghostty is already installed."
fi

# Set zsh as default shell
zsh_path="$(command -v zsh || true)"
if [[ -n "$zsh_path" ]] && [[ "$SHELL" != "$zsh_path" ]]; then
    echo "Setting zsh as default shell..."
    if ! grep -qF "$zsh_path" /etc/shells; then
        echo "$zsh_path" | sudo tee -a /etc/shells >/dev/null
    fi
    if [[ "$OS" == "Darwin" ]]; then
        chsh -s "$zsh_path"
    elif command_exists usermod; then
        sudo usermod --shell "$zsh_path" "$(whoami)"
    else
        sudo chsh -s "$zsh_path" "$(whoami)"
    fi
    echo "Default shell set to $zsh_path (takes effect on next login)."
fi

# Neovim via bob (nightly build)
if command_exists bob; then
    echo "Installing Neovim nightly via bob..."
    chmod -f u+w ~/.local/share/bob/nvim-bin/nvim 2>/dev/null || true
    bob install nightly
    bob use nightly
fi

# Install mise
if ! command_exists mise; then
    if command_exists brew; then
        echo "Installing mise via Homebrew..."
        brew install mise
    else
        echo "Installing mise via official script..."
        curl https://mise.jdx.dev/install.sh | sh
    fi
    echo "Mise installed."
fi

# Trust config and install language runtimes
if command_exists mise; then
    mise trust "$HOME/.config/mise/config.toml"
    mise install
    eval "$(mise activate bash)"
fi

# Claude Code (native installer with auto-updates)
if ! command_exists claude; then
    echo "Installing Claude Code..."
    curl -fsSL https://claude.ai/install.sh | sh
else
    echo "Claude Code is already installed."
fi
